# Mehdia — variables d'environnement
# À renseigner dans le tableau de bord Cloudflare Pages :
#   Settings → Environment variables (Production et Preview)
# En local : copier ce fichier en .dev.vars (utilisé par Wrangler).

# Clé API Claude (https://console.anthropic.com) — RESTE CÔTÉ SERVEUR
ANTHROPIC_API_KEY=

# Modèle utilisé pour l'accompagnement (par défaut : claude-sonnet-4-6)
MEHDIA_MODEL=claude-sonnet-4-6

# --- Supabase (espace client — Phase 2) ---
# Projet en région UE (Frankfurt). La clé "anon" peut être publique.
SUPABASE_URL=
SUPABASE_ANON_KEY=
